      "x": 30,
      "y": 160,
      "width": 600,
      "height": 150,
      "text": "SessionStart   (startup | resume | clear | compact)\n→ Lee history.md (últimas 30 líneas) + current.md\n     + features/in-progress.md\n→ Emite additionalContext JSON\n     → Claude recibe el contexto al iniciar",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "hook1"
    },
    {
      "type": "rectangle",
