      "x": 30,
      "y": 350,
      "width": 600,
      "height": 150,
      "text": "SessionEnd\n→ Vuelca el contenido de current.md a history.md\n→ Reinicia current.md (plantilla vacía)\n→ Auto-commit:\n     'auto: session-end checkpoint'",
      "fontSize": 18,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "hook2"
    },
