# Demo/runtime artifacts inside the plugin repo's own docs/slate/progress/ dir.
# (templates/progress/.gitignore is what end-user projects get; this section
# protects the plugin repo itself from accidentally committing those files.)
docs/slate/progress/hooks.log
docs/slate/progress/hooks.log.*
docs/slate/progress/.in-progress.snapshot
docs/slate/progress/.done.snapshot
docs/slate/progress/transcripts/
docs/slate/progress/subagents/
