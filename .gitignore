# Demo/runtime artifacts inside the plugin repo's own progress/ directory.
# (templates/progress/.gitignore is what end-user projects get; this section
# protects the plugin repo itself from accidentally committing those files.)
progress/hooks.log
progress/hooks.log.*
progress/.in-progress.snapshot
progress/.done.snapshot
progress/transcripts/
progress/subagents/
